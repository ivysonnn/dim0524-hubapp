<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <!-- Display da calculadora -->
    <LinearLayout
        android:id="@+id/display"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:gravity="end"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintBottom_toTopOf="@id/grid_buttons"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_weight="1">

        <TextView
            android:id="@+id/tv_display"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="0"
            android:textColor="@color/text_display"
            android:textSize="54sp" />


        <TextView
            android:id="@+id/tv_operation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="2dp"
            android:textColor="@color/text_operation"
            android:textSize="44sp"/>

    </LinearLayout>

    <!-- Grade de botões -->
    <GridLayout
        android:id="@+id/grid_buttons"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:alignmentMode="alignMargins"
        android:columnCount="4"
        android:rowCount="6"
        android:useDefaultMargins="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageButton
            android:id="@+id/btn_toggle"
            android:layout_width="0dp"
            android:layout_columnWeight="1"
            android:padding="16dp"
            android:src="@drawable/ic_toggle"
            android:background="?android:attr/selectableItemBackgroundBorderless" />

        <Space
            android:layout_columnSpan="3"
            android:layout_columnWeight="3"
            android:layout_gravity="fill" />

        <!-- Linha 1 -->
        <Button
            android:id="@+id/btn_clear"
            android:layout_width="0dp"
            android:layout_columnWeight="1"
            android:padding="16dp"
            android:text="C"
            android:textColor="@android:color/holo_red_dark"
            android:textSize="34sp" />

        <Button
            android:id="@+id/btn_backspace"
            android:layout_width="0dp"
            android:layout_columnWeight="1"
            android:padding="16dp"
            android:text="⌫"
            android:textColor="@color/text_button"
            android:textSize="34sp" />

        <Button
            android:id="@+id/btn_percent"
            android:layout_width="0dp"
            android:layout_columnWeight="1"
            android:backgroundTint="@color/operation_color"
            android:padding="16dp"
            android:text="%"
            android:textColor="@color/text_button"
            android:textSize="34sp" />

        <Button
            android:id="@+id/btn_divide"
            android:layout_width="0dp"
            android:layout_columnWeight="1"
            android:backgroundTint="@color/operation_color"
            android:padding="16dp"
            android:text="÷"
            android:textColor="@color/text_button"
            android:textSize="34sp" />

        <!-- Linha 2 -->
        <Button
            android:id="@+id/btn7"
            android:layout_width="0dp"
            android:layout_columnWeight="1"
            android:padding="16dp"
            android:text="7"
            android:textColor="@color/text_button"
            android:textSize="34sp" />

        <Button
            android:id="@+id/btn8"
            android:layout_width="0dp"
            android:layout_columnWeight="1"
            android:padding="16dp"
            android:text="8"
            android:textColor="@color/text_button"
            android:textSize="34sp" />

        <Button
            android:id="@+id/btn9"
            android:layout_width="0dp"
            android:layout_columnWeight="1"
            android:padding="16dp"
            android:text="9"
            android:textColor="@color/text_button"
            android:textSize="34sp" />

        <Button
            android:id="@+id/btn_multiply"
            android:layout_width="0dp"
            android:layout_columnWeight="1"
            android:backgroundTint="@color/operation_color"
            android:padding="16dp"
            android:text="×"
            android:textColor="@color/text_button"
            android:textSize="34sp" />

        <!-- Linha 3 -->
        <Button
            android:id="@+id/btn4"
            android:layout_width="0dp"
            android:layout_columnWeight="1"
            android:padding="16dp"
            android:text="4"
            android:textColor="@color/text_button"
            android:textSize="34sp" />

        <Button
            android:id="@+id/btn5"
            android:layout_width="0dp"
            android:layout_columnWeight="1"
            android:padding="16dp"
            android:text="5"
            android:textColor="@color/text_button"
            android:textSize="34sp" />

        <Button
            android:id="@+id/btn6"
            android:layout_width="0dp"
            android:layout_columnWeight="1"
            android:padding="16dp"
            android:text="6"
            android:textColor="@color/text_button"
            android:textSize="34sp" />

        <Button
            android:id="@+id/btn_subtract"
            android:layout_width="0dp"
            android:layout_columnWeight="1"
            android:backgroundTint="@color/operation_color"
            android:padding="16dp"
            android:text="-"
            android:textColor="@color/text_button"
            android:textSize="34sp" />

        <!-- Linha 4 -->
        <Button
            android:id="@+id/btn1"
            android:layout_width="0dp"
            android:layout_columnWeight="1"
            android:padding="16dp"
            android:text="1"
            android:textColor="@color/text_button"
            android:textSize="34sp" />

        <Button
            android:id="@+id/btn2"
            android:layout_width="0dp"
            android:layout_columnWeight="1"
            android:padding="16dp"
            android:text="2"
            android:textColor="@color/text_button"
            android:textSize="34sp" />

        <Button
            android:id="@+id/btn3"
            android:layout_width="0dp"
            android:layout_columnWeight="1"
            android:padding="16dp"
            android:text="3"
            android:textColor="@color/text_button"
            android:textSize="34sp" />

        <Button
            android:id="@+id/btn_sum"
            android:layout_width="0dp"
            android:layout_columnWeight="1"
            android:backgroundTint="@color/operation_color"
            android:padding="16dp"
            android:text="+"
            android:textColor="@color/text_button"
            android:textSize="34sp" />

        <!-- Linha 5 -->

        <Button
            android:id="@+id/btn_dot"
            android:layout_width="0dp"
            android:layout_columnWeight="1"
            android:padding="16dp"
            android:text="."
            android:textColor="@color/text_button"
            android:textSize="34sp" />

        <Button
            android:id="@+id/btn0"
            android:layout_width="0dp"
            android:layout_columnWeight="1"
            android:padding="16dp"
            android:text="0"
            android:textColor="@color/text_button"
            android:textSize="34sp" />

        <Button
            android:id="@+id/btn_equals"
            android:layout_width="0dp"
            android:layout_columnWeight="2"
            android:layout_columnSpan="2"
            android:backgroundTint="@color/equal"
            android:padding="16dp"
            android:text="="
            android:textColor="@color/text_button"
            android:textSize="34sp" />
    </GridLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
