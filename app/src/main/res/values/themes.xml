<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.Hub" parent="Theme.Material3.DayNight.NoActionBar">

        <!-- Primary -->
        <item name="colorPrimary">@color/blue_primary</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Background / Surface -->
        <item name="android:colorBackground">@color/white</item>
        <item name="colorSurface">@color/gray_surface</item>
        <item name="colorOnSurface">@color/black</item>

        <!-- Customizing Outlined Button Style Globally -->
        <item name="materialButtonOutlinedStyle">@style/Widget.App.Button.Outlined</item>
    </style>

    <style name="Widget.App.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/blue_primary</item>
        <item name="android:textColor">@color/blue_primary</item>
    </style>
</resources>