<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="32dp"
    tools:context="br.ufrn.dim0524.hub.bascore.BascoreActivity">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp">

        <ImageButton
            android:id="@+id/btn_return_bascore"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/back"
            android:src="@drawable/ic_return" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:fontFamily="monospace"
            android:gravity="center"
            android:text="Bascore"
            android:textSize="32sp"
            android:textStyle="bold" />

    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:baselineAligned="false"
        android:gravity="center"
        android:orientation="horizontal">

        <!-- Time A -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <TextView
                android:id="@+id/timeA"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Time A"
                android:textColor="@color/team_a_color"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/placarTimeA"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="@color/team_a_color"
                android:textSize="140sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:orientation="vertical">

                <Button
                    android:id="@+id/tresPontosA"
                    android:layout_width="280dp"
                    android:layout_height="72dp"
                    android:layout_margin="8dp"
                    android:backgroundTint="@color/team_a_color"
                    android:text="+3 PONTOS"
                    android:textSize="18sp" />

                <Button
                    android:id="@+id/doisPontosA"
                    android:layout_width="280dp"
                    android:layout_height="72dp"
                    android:layout_margin="8dp"
                    android:backgroundTint="@color/team_a_color"
                    android:text="+2 PONTOS"
                    android:textSize="18sp" />

                <Button
                    android:id="@+id/tiroLivreA"
                    android:layout_width="280dp"
                    android:layout_height="72dp"
                    android:layout_margin="8dp"
                    android:backgroundTint="@color/team_a_color"
                    android:text="@string/free_throw"
                    android:textSize="18sp" />
            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="2dp"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="48dp"
            android:layout_marginVertical="32dp"
            android:background="@android:color/darker_gray" />

        <!-- Time B -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <TextView
                android:id="@+id/timeB"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Time B"
                android:textColor="@color/team_b_color"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/placarTimeB"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="@color/team_b_color"
                android:textSize="140sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:orientation="vertical">

                <Button
                    android:id="@+id/tresPontosB"
                    android:layout_width="280dp"
                    android:layout_height="72dp"
                    android:layout_margin="8dp"
                    android:backgroundTint="@color/team_b_color"
                    android:text="+3 PONTOS"
                    android:textSize="18sp" />

                <Button
                    android:id="@+id/doisPontosB"
                    android:layout_width="280dp"
                    android:layout_height="72dp"
                    android:layout_margin="8dp"
                    android:backgroundTint="@color/team_b_color"
                    android:text="+2 PONTOS"
                    android:textSize="18sp" />

                <Button
                    android:id="@+id/tiroLivreB"
                    android:layout_width="280dp"
                    android:layout_height="72dp"
                    android:layout_margin="8dp"
                    android:backgroundTint="@color/team_b_color"
                    android:text="@string/free_throw"
                    android:textSize="18sp" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

    <Button
        android:id="@+id/reiniciarPartida"
        style="?attr/materialButtonOutlinedStyle"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_marginTop="32dp"
        android:text="@string/reset_game"
        android:textSize="22sp" />

</LinearLayout>