<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="8dp">

    <LinearLayout
        android:id="@+id/display"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:gravity="end|center_vertical"
        android:orientation="vertical"
        android:padding="0dp"
        app:layout_constraintBottom_toTopOf="@id/grid_buttons"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_weight="1">

        <TextView
            android:id="@+id/tv_display"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="@android:color/black"
            android:textSize="34sp" />

        <TextView
            android:id="@+id/tv_operation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:padding="2dp"
            android:textColor="@android:color/darker_gray"
            android:textSize="20sp" />
    </LinearLayout>

    <GridLayout
        android:id="@+id/grid_buttons"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:alignmentMode="alignMargins"
        android:columnCount="6"
        android:rowCount="6"
        android:useDefaultMargins="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageButton
            android:id="@+id/btn_toggle"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_columnWeight="1"
            android:layout_marginEnd="50dp"
            android:src="@drawable/ic_toggle"
            android:background="?android:attr/selectableItemBackgroundBorderless" />

        <Space
            android:layout_columnSpan="5"
            android:layout_columnWeight="5"
            android:layout_gravity="fill" />

        <!-- LINHA 1 -->
        <Button
            android:id="@+id/btn_sin"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_columnWeight="1"
            android:layout_marginEnd="50dp"
            android:text="@string/sin"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btn_sqrroot"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_columnWeight="1"
            android:layout_marginEnd="50dp"
            android:text="√"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btn_clear"
            android:layout_width="0dp"
            android:layout_columnWeight="1"
            android:layout_marginEnd="50dp"
            android:textColor="@android:color/holo_red_dark"
            android:text="C"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btn_backspace"
            android:layout_width="0dp"
            android:layout_columnWeight="1"
            android:layout_marginEnd="50dp"
            android:text="⌫"
            android:textSize="16sp" />
        <Button
            android:id="@+id/btn_percent"
            android:layout_width="0dp"
            android:layout_columnWeight="1"
            android:layout_marginEnd="50dp"
            android:text="%"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btn_divide"
            android:layout_width="0dp"
            android:layout_columnWeight="1"
            android:text="÷"
            android:textSize="16sp" />

        <!-- LINHA 2 -->
        <Button
            android:id="@+id/btn_cos"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_columnWeight="1"
            android:layout_marginEnd="50dp"
            android:text="cos"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btn_pow"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_columnWeight="1"
            android:layout_marginEnd="50dp"
            android:text="x²"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btn7"
            android:layout_width="0dp"
            android:layout_columnWeight="1"
            android:layout_marginEnd="50dp"
            android:text="7"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btn8"
            android:layout_width="0dp"
            android:layout_columnWeight="1"
            android:layout_marginEnd="50dp"
            android:text="8"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btn9"
            android:layout_width="0dp"
            android:layout_columnWeight="1"
            android:layout_marginEnd="50dp"
            android:text="9"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btn_multiply"
            android:layout_width="0dp"
            android:layout_columnWeight="1"
            android:text="×"
            android:textSize="16sp" />

        <!-- LINHA 3 -->
        <Button
            android:id="@+id/btn_tan"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_columnWeight="1"
            android:layout_marginEnd="50dp"
            android:text="tan"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btn_fac"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_columnWeight="1"
            android:layout_marginEnd="50dp"
            android:text="x!"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btn4"
            android:layout_width="0dp"
            android:layout_columnWeight="1"
            android:layout_marginEnd="50dp"
            android:text="4"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btn5"
            android:layout_width="0dp"
            android:layout_columnWeight="1"
            android:layout_marginEnd="50dp"
            android:text="5"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btn6"
            android:layout_width="0dp"
            android:layout_columnWeight="1"
            android:layout_marginEnd="50dp"
            android:text="6"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btn_subtract"
            android:layout_width="0dp"
            android:layout_columnWeight="1"
            android:text="-"
            android:textSize="16sp" />

        <!-- LINHA 4 -->
        <Button
            android:id="@+id/btn_log"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_columnWeight="1"
            android:layout_marginEnd="50dp"
            android:text="log"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btn_ln"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_columnWeight="1"
            android:layout_marginEnd="50dp"
            android:text="ln"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btn1"
            android:layout_width="0dp"
            android:layout_columnWeight="1"
            android:layout_marginEnd="50dp"
            android:text="1"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btn2"
            android:layout_width="0dp"
            android:layout_columnWeight="1"
            android:layout_marginEnd="50dp"
            android:text="2"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btn3"
            android:layout_width="0dp"
            android:layout_columnWeight="1"
            android:layout_marginEnd="50dp"
            android:text="3"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btn_sum"
            android:layout_width="0dp"
            android:layout_columnWeight="1"
            android:text="+"
            android:textSize="16sp" />

        <!-- LINHA 5 -->
        <Button
            android:id="@+id/btn_pi"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_columnWeight="1"
            android:layout_marginEnd="50dp"
            android:text="π"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btn_euler"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_columnWeight="1"
            android:layout_marginEnd="50dp"
            android:text="e"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btn_dot"
            android:layout_width="0dp"
            android:layout_columnWeight="1"
            android:layout_marginEnd="50dp"
            android:text="."
            android:textSize="16sp" />

        <Button
            android:id="@+id/btn0"
            android:layout_width="0dp"
            android:layout_columnWeight="1"
            android:layout_marginEnd="50dp"
            android:text="0"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btn_equals"
            android:layout_width="0dp"
            android:layout_columnWeight="2"
            android:layout_columnSpan="2"
            android:backgroundTint="@color/equal"
            android:text="="
            android:textSize="16sp" />

    </GridLayout>
</androidx.constraintlayout.widget.ConstraintLayout>